# ============================================================
#  Ingrexa — Environment Variable Template
#  Copy this file to `.env` and fill in your real values.
#  NEVER commit your real `.env` to version control!
# ============================================================

# ── Django Core ─────────────────────────────────────────────
# Generate a fresh secret key:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-super-secret-key-here-change-this-in-production

# Set to False in production!
DEBUG=True

# Comma-separated list of allowed hosts
# Production example: myapp.onrender.com,www.myapp.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated CORS origins
# Production example: https://myapp.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Frontend ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
# ── Database ─────────────────────────────────────────────────
# PostgreSQL (Supabase, Render, etc.)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://user:password@host:5432/dbname
# Leave empty to fall back to local SQLite (development only)

# ── Email (Contact Form) ─────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password
CONTACT_EMAIL_RECIPIENT=contact@yourdomain.com

# ── Resend API (Transactional Email on Render) ────────────────
RESEND_API_KEY=re_your_resend_api_key_here

# ── OpenAI (Optional — for AI Ingredient Analysis) ───────────
OPENAI_API_KEY=your-openai-api-key-here

# ── Support / Donations (Optional) ────────────────────────────
# Keep this optional so the product can stay free.
DONATION_BUY_ME_A_COFFEE_URL=
DONATION_UPI_URL=
DONATION_MESSAGE=If you find Ingrexa helpful, consider supporting the creator.

# Razorpay API Keys (Full Integration)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
